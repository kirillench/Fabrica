LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
# запасные модели через запятую — автофолбэк при 429/5xx/невалидном ответе
LLM_FALLBACK_MODELS=
LLM_TEMPERATURE=0.4
DEMO_MODE=auto

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=hypothesis-factory

# Токены доступа «токен:Имя,токен2:Имя2»; пусто — аутентификация выключена
APP_TOKENS=
# Секрет подписи ссылок на файлы; пусто — выводится из APP_TOKENS
APP_SECRET=
